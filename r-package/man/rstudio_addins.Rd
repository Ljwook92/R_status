\name{rstudio_addins}
\alias{run_selection_with_status}
\alias{run_current_document_with_status}
\title{Run RStudio code with menu bar status}
\usage{
run_selection_with_status()

run_current_document_with_status()
}
\value{The last evaluated value, invisibly.}
\description{
RStudio Addin bindings that execute the active selection or the current document
and report running, completion, and failure to the menu bar app.
}
